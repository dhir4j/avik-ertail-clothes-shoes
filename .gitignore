# ─────────────────────────────────────────
# SOLESTREET — .gitignore
# ─────────────────────────────────────────

# ── Environment & Secrets ────────────────
.env
.env.*
!.env.example
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env.local
frontend/.env.production.local

# ── Python — Backend & Scraper ───────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# Flask instance folder (SQLite DB, uploaded files)
backend/instance/
instance/

# Python eggs & packaging
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
backend/lib/
backend/lib64/

# pytest / testing
.pytest_cache/
.tox/
htmlcov/
.coverage
coverage.xml
*.cover

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# ── Node.js — Frontend ───────────────────
node_modules/
frontend/node_modules/

# Next.js build output
.next/
frontend/.next/
out/
frontend/out/

# Next.js cache & telemetry
.next/cache/
frontend/.next/cache/
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo
next-env.d.ts
frontend/next-env.d.ts

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/
.pnp.*
pnpm-debug.log*

# ── Databases ────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────
logs/
*.log
log/

# ── OS & Editor files ────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

.idea/
.vscode/
*.swp
*.swo
*~

# ── Scraper artifacts ────────────────────
scraper/*.html
scraper/t1.txt
scraper/__pycache__/
scraper/metro_scraper/__pycache__/

# ── Misc ─────────────────────────────────
*.bak
*.tmp
*.orig
.cache/
